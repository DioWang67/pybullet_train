<?xml version="1.0"?>
<!--
  Ball Walker Robot
  軀幹：球體 r=0.25m  (50cm 直徑)
  大腿：圓柱 h=0.15m  小腿：圓柱 h=0.15m  腳：扁箱
  總質量 ≈ 40kg
  關節：hip / knee / ankle  × 2，全為 revolute (矢狀面 y-axis)
-->
<robot name="ball_walker">

  <material name="blue">  <color rgba="0.20 0.45 0.85 1"/></material>
  <material name="gray">  <color rgba="0.55 0.55 0.55 1"/></material>
  <material name="light"> <color rgba="0.75 0.80 0.90 1"/></material>
  <material name="dark">  <color rgba="0.20 0.20 0.20 1"/></material>

  <!-- ════════════════════ TORSO (球體) ════════════════════ -->
  <link name="torso">
    <visual>
      <geometry><sphere radius="0.25"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.25"/></geometry>
    </collision>
    <inertial>
      <mass value="25.0"/>
      <!-- I = 2/5 * m * r^2 = 2/5 * 25 * 0.0625 = 0.625 -->
      <inertia ixx="0.625" iyy="0.625" izz="0.625"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ════════════════════ LEFT LEG ════════════════════ -->

  <link name="left_thigh">
    <visual>
      <origin xyz="0 0 -0.075"/>
      <geometry><cylinder radius="0.04" length="0.15"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075"/>
      <geometry><cylinder radius="0.04" length="0.15"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075"/>
      <mass value="5.5"/>
      <!-- Ixx=Iyy=1/12*m*(3r²+h²)=1/12*5.5*(0.0048+0.0225)=0.01251 -->
      <!-- Izz=1/2*m*r²=0.5*5.5*0.0016=0.0044 -->
      <inertia ixx="0.01251" iyy="0.01251" izz="0.0044"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_hip" type="revolute">
    <parent link="torso"/>
    <child link="left_thigh"/>
    <origin xyz="0 0.07 -0.25"/>   <!-- 球底，偏左 0.07m -->
    <axis xyz="0 1 0"/>
    <limit lower="-0.87" upper="0.87" effort="150" velocity="8"/>
    <dynamics damping="0.2" friction="0"/>
  </joint>

  <link name="left_shin">
    <visual>
      <origin xyz="0 0 -0.075"/>
      <geometry><cylinder radius="0.03" length="0.15"/></geometry>
      <material name="light"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075"/>
      <geometry><cylinder radius="0.03" length="0.15"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075"/>
      <mass value="2.0"/>
      <!-- Ixx=Iyy=1/12*2*(0.0027+0.0225)=0.0042  Izz=0.5*2*0.0009=0.0009 -->
      <inertia ixx="0.0042" iyy="0.0042" izz="0.0009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_knee" type="revolute">
    <parent link="left_thigh"/>
    <child link="left_shin"/>
    <origin xyz="0 0 -0.15"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.40" upper="0.0" effort="100" velocity="8"/>
    <dynamics damping="0.2" friction="0"/>
  </joint>

  <link name="left_foot">
    <visual>
      <origin xyz="0.05 0 -0.02"/>
      <geometry><box size="0.12 0.07 0.04"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0.05 0 -0.02"/>
      <geometry><box size="0.12 0.07 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.05 0 -0.02"/>
      <mass value="0.5"/>
      <!-- box: Ixx=1/12*m*(w²+h²), Iyy=1/12*m*(l²+h²), Izz=1/12*m*(l²+w²) -->
      <inertia ixx="0.000271" iyy="0.000667" izz="0.000804"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_ankle" type="revolute">
    <parent link="left_shin"/>
    <child link="left_foot"/>
    <origin xyz="0 0 -0.15"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.45" upper="0.45" effort="60" velocity="8"/>
    <dynamics damping="0.1" friction="0"/>
  </joint>

  <!-- ════════════════════ RIGHT LEG ════════════════════ -->

  <link name="right_thigh">
    <visual>
      <origin xyz="0 0 -0.075"/>
      <geometry><cylinder radius="0.04" length="0.15"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075"/>
      <geometry><cylinder radius="0.04" length="0.15"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075"/>
      <mass value="5.5"/>
      <inertia ixx="0.01251" iyy="0.01251" izz="0.0044"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_hip" type="revolute">
    <parent link="torso"/>
    <child link="right_thigh"/>
    <origin xyz="0 -0.07 -0.25"/>  <!-- 球底，偏右 0.07m -->
    <axis xyz="0 1 0"/>
    <limit lower="-0.87" upper="0.87" effort="150" velocity="8"/>
    <dynamics damping="0.2" friction="0"/>
  </joint>

  <link name="right_shin">
    <visual>
      <origin xyz="0 0 -0.075"/>
      <geometry><cylinder radius="0.03" length="0.15"/></geometry>
      <material name="light"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075"/>
      <geometry><cylinder radius="0.03" length="0.15"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075"/>
      <mass value="2.0"/>
      <inertia ixx="0.0042" iyy="0.0042" izz="0.0009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_knee" type="revolute">
    <parent link="right_thigh"/>
    <child link="right_shin"/>
    <origin xyz="0 0 -0.15"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.40" upper="0.0" effort="100" velocity="8"/>
    <dynamics damping="0.2" friction="0"/>
  </joint>

  <link name="right_foot">
    <visual>
      <origin xyz="0.05 0 -0.02"/>
      <geometry><box size="0.12 0.07 0.04"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0.05 0 -0.02"/>
      <geometry><box size="0.12 0.07 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.05 0 -0.02"/>
      <mass value="0.5"/>
      <inertia ixx="0.000271" iyy="0.000667" izz="0.000804"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_ankle" type="revolute">
    <parent link="right_shin"/>
    <child link="right_foot"/>
    <origin xyz="0 0 -0.15"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.45" upper="0.45" effort="60" velocity="8"/>
    <dynamics damping="0.1" friction="0"/>
  </joint>

</robot>
