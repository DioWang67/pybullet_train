<?xml version="1.0"?>
<!--
  Ball Walker Robot  v2
  ─────────────────────────────────────────────────────────────────
  主要改動 vs v1：
  1. 軀幹質量  25kg → 10kg  (重心大幅下移，穩定性↑)
  2. 大腿+小腿  各 0.15m → 0.20m  (更長的槓桿臂，控制容量↑)
  3. 新增 hip abduction joint (axis X)，每腿共 3 DOF：
       abd(X) → flex(Y) → knee(Y) → ankle(Y)
  4. 站距  ±0.07 → ±0.12m  (支撐多邊形更寬)
  5. 腳 collision 中心置中 (移除 0.05 前偏)，ankle range ±0.60
  6. hip_abd_link 為輕量過渡連桿 (0.01 kg)

  DOF summary (per leg):  abd, flex, knee, ankle  × 2 = 8 joints total
  總質量 ≈ 28 kg
-->
<robot name="ball_walker">

  <material name="blue">  <color rgba="0.20 0.45 0.85 1"/></material>
  <material name="gray">  <color rgba="0.55 0.55 0.55 1"/></material>
  <material name="light"> <color rgba="0.75 0.80 0.90 1"/></material>
  <material name="dark">  <color rgba="0.20 0.20 0.20 1"/></material>
  <material name="red">   <color rgba="0.85 0.20 0.20 1"/></material>

  <!-- ════════════════════ TORSO (球體) ════════════════════ -->
  <link name="torso">
    <visual>
      <geometry><sphere radius="0.25"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.25"/></geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <!-- I = 2/5 * m * r^2 = 2/5 * 10 * 0.0625 = 0.25 -->
      <inertia ixx="0.25" iyy="0.25" izz="0.25"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ════════════════════ LEFT LEG ════════════════════ -->

  <!--
    過渡連桿：left_hip_abd_link
    幾乎無質量，僅作為 abduction 關節的 child frame
  -->
  <link name="left_hip_abd_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Hip abduction (側向) — axis X -->
  <joint name="left_hip_abd" type="revolute">
    <parent link="torso"/>
    <child link="left_hip_abd_link"/>
    <origin xyz="0 0.12 -0.25"/>     <!-- 球底，偏左 0.12m -->
    <axis xyz="1 0 0"/>
    <limit lower="-0.35" upper="0.35" effort="120" velocity="8"/>
    <dynamics damping="0.3" friction="0"/>
  </joint>

  <link name="left_thigh">
    <visual>
      <origin xyz="0 0 -0.10"/>
      <geometry><cylinder radius="0.04" length="0.20"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.10"/>
      <geometry><cylinder radius="0.04" length="0.20"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.10"/>
      <mass value="6.0"/>
      <!--
        Ixx=Iyy = 1/12*m*(3r²+h²) = 1/12*6*(3*0.0016+0.04) = 1/12*6*0.0448 = 0.02240
        Izz     = 1/2*m*r²        = 0.5*6*0.0016 = 0.00480
      -->
      <inertia ixx="0.02240" iyy="0.02240" izz="0.00480"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Hip flexion (前後) — axis Y -->
  <joint name="left_hip_flex" type="revolute">
    <parent link="left_hip_abd_link"/>
    <child link="left_thigh"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.87" upper="0.87" effort="150" velocity="8"/>
    <dynamics damping="0.2" friction="0"/>
  </joint>

  <link name="left_shin">
    <visual>
      <origin xyz="0 0 -0.10"/>
      <geometry><cylinder radius="0.03" length="0.20"/></geometry>
      <material name="light"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.10"/>
      <geometry><cylinder radius="0.03" length="0.20"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.10"/>
      <mass value="2.5"/>
      <!--
        Ixx=Iyy = 1/12*2.5*(3*0.0009+0.04) = 1/12*2.5*0.0427 = 0.00889
        Izz     = 0.5*2.5*0.0009 = 0.001125
      -->
      <inertia ixx="0.00889" iyy="0.00889" izz="0.001125"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_knee" type="revolute">
    <parent link="left_thigh"/>
    <child link="left_shin"/>
    <origin xyz="0 0 -0.20"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.40" upper="0.0" effort="100" velocity="8"/>
    <dynamics damping="0.2" friction="0"/>
  </joint>

  <link name="left_foot">
    <visual>
      <origin xyz="0 0 -0.02"/>
      <geometry><box size="0.14 0.08 0.04"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.02"/>
      <geometry><box size="0.14 0.08 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.02"/>
      <mass value="0.6"/>
      <!--
        box 0.14×0.08×0.04
        Ixx = 1/12*0.6*(0.08²+0.04²) = 1/12*0.6*(0.0064+0.0016) = 0.000400
        Iyy = 1/12*0.6*(0.14²+0.04²) = 1/12*0.6*(0.0196+0.0016) = 0.001060
        Izz = 1/12*0.6*(0.14²+0.08²) = 1/12*0.6*(0.0196+0.0064) = 0.001300
      -->
      <inertia ixx="0.000400" iyy="0.001060" izz="0.001300"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_ankle" type="revolute">
    <parent link="left_shin"/>
    <child link="left_foot"/>
    <origin xyz="0 0 -0.20"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.60" upper="0.60" effort="60" velocity="8"/>
    <dynamics damping="0.1" friction="0"/>
  </joint>

  <!-- ════════════════════ RIGHT LEG ════════════════════ -->

  <link name="right_hip_abd_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_hip_abd" type="revolute">
    <parent link="torso"/>
    <child link="right_hip_abd_link"/>
    <origin xyz="0 -0.12 -0.25"/>   <!-- 球底，偏右 0.12m -->
    <axis xyz="1 0 0"/>
    <limit lower="-0.35" upper="0.35" effort="120" velocity="8"/>
    <dynamics damping="0.3" friction="0"/>
  </joint>

  <link name="right_thigh">
    <visual>
      <origin xyz="0 0 -0.10"/>
      <geometry><cylinder radius="0.04" length="0.20"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.10"/>
      <geometry><cylinder radius="0.04" length="0.20"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.10"/>
      <mass value="6.0"/>
      <inertia ixx="0.02240" iyy="0.02240" izz="0.00480"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_hip_flex" type="revolute">
    <parent link="right_hip_abd_link"/>
    <child link="right_thigh"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.87" upper="0.87" effort="150" velocity="8"/>
    <dynamics damping="0.2" friction="0"/>
  </joint>

  <link name="right_shin">
    <visual>
      <origin xyz="0 0 -0.10"/>
      <geometry><cylinder radius="0.03" length="0.20"/></geometry>
      <material name="light"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.10"/>
      <geometry><cylinder radius="0.03" length="0.20"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.10"/>
      <mass value="2.5"/>
      <inertia ixx="0.00889" iyy="0.00889" izz="0.001125"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_knee" type="revolute">
    <parent link="right_thigh"/>
    <child link="right_shin"/>
    <origin xyz="0 0 -0.20"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.40" upper="0.0" effort="100" velocity="8"/>
    <dynamics damping="0.2" friction="0"/>
  </joint>

  <link name="right_foot">
    <visual>
      <origin xyz="0 0 -0.02"/>
      <geometry><box size="0.14 0.08 0.04"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.02"/>
      <geometry><box size="0.14 0.08 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.02"/>
      <mass value="0.6"/>
      <inertia ixx="0.000400" iyy="0.001060" izz="0.001300"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_ankle" type="revolute">
    <parent link="right_shin"/>
    <child link="right_foot"/>
    <origin xyz="0 0 -0.20"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.60" upper="0.60" effort="60" velocity="8"/>
    <dynamics damping="0.1" friction="0"/>
  </joint>

</robot>
